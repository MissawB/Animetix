# ==========================================================================
# Image BRAIN (deploy/Dockerfile.brain) — standalone GPU FastAPI service.
# ==========================================================================
# Versions inherited from the union lockfile via the constraint below.
# Recompile: pip-compile --allow-unsafe --strip-extras --output-file=requirements-brain.txt requirements-brain.in
#
# Django-free by design (verified: nothing in the brain_service import closure
# touches Django — it talks to the web side over HTTP only). CUDA torch is
# intentional here: this is the only image that actually runs models on GPU.
#
# S2S: Kyutai STT (transformers-native, kyutai/stt-1b-en_fr-trfs) -> brain LLM ->
# XTTS-v2 (coqui-tts) cascade. Uses transformers + coqui-tts already locked below;
# the `moshi` package is intentionally NOT added (it caps safetensors<0.8.0, which
# conflicts with diffusers==0.39.0). See audio_mixin.speech_to_speech and
# docs/superpowers/specs/2026-07-17-brain-moshi-s2s-kyutai-cascade-design.md.
-c requirements.txt

# Serving
fastapi
uvicorn
pydantic
pydantic-settings

# Security / IO helpers used by core.utils.security
httpx
filetype
bleach
orjson

# GPU / ML serving stack
torch
transformers
sentence-transformers
colpali-engine
diffusers
accelerate
bitsandbytes
coqui-tts
numpy
scipy
pillow
imageio
pydub

# Visual search (Task 5b): the brain is the only host with the GPU + weights,
# so it must serve get_image_embedding/get_text_embedding_clip (anime CLIP,
# open_clip_torch -- see clip_vision.py) and get_character_embedding (CCIP,
# onnxruntime -- see ccip_vision.py) for the web container's production chain
# ([brain_api, google_genai]) to have anyone to delegate to.
open_clip_torch
onnxruntime

# Observability (best-effort in brain_service lifespan/middleware)
opentelemetry-api
opentelemetry-sdk
opentelemetry-exporter-gcp-trace
google-cloud-profiler
sentry-sdk
