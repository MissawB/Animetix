  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:coverage": "vitest run --project unit --coverage",
    "test:e2e": "playwright test --grep @e2e",
    "test:vrt": "playwright test e2e/vrt.spec.ts",
    "test:vrt:update": "playwright test e2e/vrt.spec.ts --update-snapshots",
    "check-types": "tsc --noEmit",
    "generate:api": "npx openapi-typescript ../schema.yaml -o src/types/api.d.ts",
    "sync": "cd .. && sync-api.bat",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
