# ==============================================================================
# Animetix - Environment Variables Template (.env.example)
# ==============================================================================
# Copy this file to .env and fill in your local values.
# IMPORTANT: Never commit your actual .env file to version control.

# --- Django Settings ---
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-insecure-animetix-2026-v2-local-only
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (Docker & Django) ---
POSTGRES_DB=animetix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
# Internal Docker connection for Django
DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/animetix

# --- Redis (Docker & Django) ---
REDIS_URL=redis://redis:6379/0

# --- Neo4j (Docker & Application) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password_here
# Used by Docker (Format: user/password)
NEO4J_AUTH=neo4j/your_secure_password_here
NEO4J_URI=bolt://neo4j:7687

# --- ChromaDB (Docker & Application) ---
# Used by Docker (Server)
CHROMA_SERVER_AUTH_CREDENTIALS=animetix:your_secure_password_here
CHROMA_SERVER_AUTH_PROVIDER=chromadb.auth.basic.BasicAuthProvider
# Used by Application (Client)
CHROMA_CLIENT_AUTH_CREDENTIALS=animetix:your_secure_password_here
CHROMA_CLIENT_AUTH_PROVIDER=chromadb.auth.basic.BasicAuthProvider
# Used by Application
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- External APIs & Services ---
BRAIN_API_URL=http://localhost:5000
BRAIN_API_KEY=REQUIRED_SECURE_KEY_IN_PROD
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=llama3
LOCAL_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
SENTRY_DSN=

# --- Feature Flags ---
FEATURE_EXPERIMENTAL_MODES=True
FEATURE_BETA_SOCIAL=True
FEATURE_AI_DEBUG=True

# --- Google Cloud Storage CMEK (Cloud KMS) ---
# Optional: Resource name of the Cloud KMS key used to encrypt GCS blobs
# Format: projects/<project-id>/locations/<region>/keyRings/<keyring-name>/cryptoKeys/<key-name>
GS_DEFAULT_KMS_KEY_NAME=

# --- Tachidesk/Suwayomi ---
SUWAYOMI_URL=http://127.0.0.1:4567
SUWAYOMI_PASSWORD=

