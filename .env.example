# ==============================================================================
# Animetix - Environment Variables Template (.env.example)
# ==============================================================================
# Copy this file to .env and fill in your local values.
# IMPORTANT: Never commit your actual .env file to version control.
# NB: the frontend has its own build-time config in frontend/.env
#     (VITE_FIREBASE_*, VITE_ADSENSE_*, VITE_SPONSOR_*) — not covered by
#     this file.

# --- Django Settings ---
DJANGO_ENV=development
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=dev-insecure-animetix-2026-v2-local-only
ALLOWED_HOSTS=localhost,127.0.0.1

# --- PostgreSQL (Docker & Django) ---
POSTGRES_DB=animetix
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
# Internal Docker connection for Django
DATABASE_URL=postgres://postgres:your_secure_password_here@db:5432/animetix

# --- Redis (Docker & Django) ---
REDIS_URL=redis://redis:6379/0

# --- Neo4j (Docker & Application) ---
# The code reads NEO4J_USER (not NEO4J_USERNAME). On Aura, the username is
# the INSTANCE ID (e.g. "1254b9b8"), not "neo4j".
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_secure_password_here
# Used by Docker (Format: user/password)
NEO4J_AUTH=neo4j/your_secure_password_here
NEO4J_URI=bolt://neo4j:7687

# --- Brain (GPU inference service) ---
BRAIN_API_URL=http://localhost:5000
BRAIN_API_KEY=REQUIRED_SECURE_KEY_IN_PROD

# --- Local LLM (Ollama / OpenAI-compatible endpoint) ---
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=qwen3.5
LOCAL_MODEL_ID=Qwen/Qwen3.5-4B

# --- AI providers ---
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=
COHERE_API_KEY=
TAVILY_API_KEY=

# --- Media catalogs (scrapers / enrichment) ---
TMDB_API_KEY=your_tmdb_api_key_here
IGDB_CLIENT_ID=your_igdb_client_id_here
IGDB_CLIENT_SECRET=your_igdb_client_secret_here

# --- Hugging Face ---
# HF_TOKEN: read token (models/datasets). HUGGINGFACE_API_KEY: same value,
# read under this name by some adapters. HF_SPACES: write token used only by
# the deploy scripts (scripts/deploy/huggingface/hf_deploy.py).
HF_TOKEN=your_hf_token_here
HUGGINGFACE_API_KEY=your_hf_token_here
HF_SPACES=

# --- MLOps / experiment tracking ---
WANDB_API_KEY=

# --- Observability ---
SENTRY_DSN=

# --- Feature Flags ---
FEATURE_EXPERIMENTAL_MODES=True
FEATURE_BETA_SOCIAL=True
FEATURE_AI_DEBUG=True

# --- Google Cloud Storage CMEK (Cloud KMS) ---
# Optional: Resource name of the Cloud KMS key used to encrypt GCS blobs
# Format: projects/<project-id>/locations/<region>/keyRings/<keyring-name>/cryptoKeys/<key-name>
GS_DEFAULT_KMS_KEY_NAME=

# --- Tachidesk/Suwayomi ---
SUWAYOMI_URL=http://127.0.0.1:4567
SUWAYOMI_PASSWORD=

# --- Gemini model roles (canonical; override per environment) ---
ANIMETIX_GEMINI_MODEL=gemini-3.5-flash
ANIMETIX_GEMINI_LIVE_MODEL=gemini-live-2.5-flash-native-audio
ANIMETIX_GEMINI_EMBEDDING_MODEL=gemini-embedding-2
