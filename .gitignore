data/processed/manga_covers_failures.json
# Stray npm install at repo root (real frontend deps live in frontend/)
/package.json
/package-lock.json


# Local agent tooling (skills manifests, editor-extension cruft)
.agents/

# Artefact Windows récurrent : lint-staged passe core.hooksPath=/dev/null à ses
# commandes git internes, et git-lfs y "répare" ses hooks → dossier littéral
# dev/null/ recréé à chaque commit. Inoffensif, on l'ignore.
/dev/

# Claude Code session/harness directory
.claude/

# dbt build artifacts & local state
backend/pipeline/dbt_project/target/
backend/pipeline/dbt_project/.user.yml
# profiles.yml est GÉNÉRÉ par run_data_quality_tests (chemins absolus locaux) :
# le tracker garantissait un working tree sale après chaque run.
backend/pipeline/dbt_project/profiles.yml

# Uploaded media (generated at runtime, not source)
backend/api/media/

# Frontend test coverage reports
frontend/coverage/
coverage/
# Backend coverage report (pytest --cov)
coverage.xml

# Catalogue offline généré au runtime (SQLite), pas une source
backend/api/animetix/static/animetix/data/
.playwright-mcp/
