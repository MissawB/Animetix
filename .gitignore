/Double_scenario_Project/

# Frontend lint dumps (scratch output, not source)
frontend/lint_*.txt
frontend/lint_*.json
# Scratch pipeline outputs (re-excluded after the data/processed/*.json allow above)
data/processed/temp_test_*.json
data/processed/failed_attempts.json
