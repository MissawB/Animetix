# ==========================================================================
# Double_scenario_Project – Dépendances de DEV / TEST (requirements-dev.in)
# ==========================================================================
# Outils de dev/test uniquement, tenus HORS du lock de prod (requirements.txt)
# pour que les images Docker n'embarquent pas pytest ni les outils de test.
# Compilé avec le lock prod comme CONTRAINTE (-c) afin que tout transitif
# partagé garde exactement la version de production.
#
# Env de dev complet :
#   pip install -r requirements.txt -r requirements-dev.txt
#
# Recompiler après édition :
#   pip-compile --allow-unsafe --strip-extras --output-file=requirements-dev.txt requirements-dev.in
-c requirements.txt

pytest==9.0.3
pytest-asyncio==1.3.0
pytest-django==4.12.0
pytest-mock==3.15.1
pytest-cov==5.0.0
coloredlogs==15.0.1
watchdog==6.0.0
