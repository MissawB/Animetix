# 4. Heavy ML/AI, Deep Learning, NLP & Computer Vision
# (ultralytics / manga-ocr / onnxruntime / opencv-python-headless / torchvision
# were removed 2026-07-11: zero imports repo-wide — dropping ultralytics also
# retired the opencv GUI-vs-headless uninstall dance in the Dockerfiles.)
bitsandbytes==0.49.2
diffusers==0.39.0
google-genai==1.75.0
numba==0.65.1
numpy==1.26.4
# peft 0.13.2 -> 0.17.1 (2026-07-11): forced by colpali-engine — no colpali
# release satisfies both peft==0.13.2 and transformers==4.57.6. Validated by
# the full test suite (multi_lora_manager + training pipelines).
peft==0.17.1
# ColPali late-interaction (brain clip_vision) — the lazy import was never in
# any lockfile until 2026-07-11, so the path silently degraded at runtime.
colpali-engine==0.3.13
# open_clip_torch (brain clip_vision): anime-tuned CLIP checkpoints on the Hub
# (e.g. dudcjs2779/anime-style-tag-clip, EVA-02) are published for OpenCLIP,
# not sentence-transformers. Pulls timm, needed for the EVA-02 vision tower.
open_clip_torch==3.3.0
# onnxruntime (brain ccip_vision): `deepghs/ccip` answers "is this the SAME
# anime character", not "does it look similar" -- a question a general-purpose
# CLIP cannot answer. CCIP ships as an ONNX graph, not a torch checkpoint.
# On charge le graphe à la main (hf_hub_download + PIL/numpy) plutôt que via
# `dghs-imgutils` : ce paquet coûtait 95 Mo, réintroduisait opencv-contrib
# (retiré volontairement le 2026-07-11) et rétrogradait chardet 7.4.3 -> 4.0.0,
# le tout pour une seule fonction. Le prétraitement est donc dans
# backend/adapters/inference/ccip_vision.py, sourcé sur l'implémentation de
# référence (voir l'en-tête du module).
onnxruntime==1.24.4
sentence-transformers==3.3.1
torch==2.5.1
transformers==4.57.6
trl==0.12.1
coqui-tts==0.27.5
imageio==2.37.3
z3-solver==4.16.0.0

# 5. GCP, Observability & Utilities
# Pinned to the versions pip-compile already resolved into requirements.txt, so
