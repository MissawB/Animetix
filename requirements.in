accelerate==1.13.0
supervisor==4.2.5
# supervisor 4.2.5 imports `pkg_resources` at startup; setuptools >=81 removed it,
# so a fresh image (setuptools auto-pinned to latest by pip-compile --allow-unsafe)
# crashes supervisord with "No module named 'pkg_resources'". Pin <81 to keep
# pkg_resources; 80.x still satisfies the Snyk setuptools CVEs (>=78.1.1).
setuptools<81
# apache-beam 2.75.0 lève le cap jsonpickle (désormais `jsonpickle<5.0.0,>=3.0.4`),
# défigeant jsonpickle 3.4.2 → 4.x (CVE CWE-502 ; jsonpickle reste purement transitif,
# jamais importé par notre code, non exploitable chez nous). Bump lockstep avec le tag de
# base Dockerfile.dataflow (beam_python3.12_sdk:2.75.0), sinon mismatch SDK → échec Dataflow.
apache-beam==2.75.0
